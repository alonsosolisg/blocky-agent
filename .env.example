# Copy this file to .env (or .env.local) and fill in your key.
# Vite requires the VITE_ prefix for variables exposed to the browser.
# After editing, restart your dev server (npm run dev).

VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: you can add other VITE_ vars if needed.
# Free OpenRouter models (as of now) are listed in BlockyPanel.tsx
# Get keys at https://openrouter.ai/keys (free tier has rate limits + daily quotas)